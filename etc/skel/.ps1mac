#source /usr/share/git/completion/git-prompt.sh
source /usr/share/git/git-prompt.sh
git_branch() {
  git branch --show-current 2>/dev/null
}

PS1='\[\e[1;32m\]●\[\e[0m\] \[\e[1;36m\]➜\[\e[0m\] \w $ '
PS1='\[\e[38;5;39m\]❯\[\e[0m\] \[\e[1;37m\]\w\[\e[0m\] \[\e[38;5;82m\]●\[\e[0m\] '
PS1='\[\e[1;32m\]●\[\e[0m\] \[\e[1;36m\]\u@\h\[\e[0m\]:\[\e[1;37m\]\w\[\e[0m\] \[\e[1;33m\]➜\[\e[0m\] '
PS1='\[\e[1;32m\]●\[\e[0m\] \[\e[1;36m\]➜\[\e[0m\] \[\e[1;37m\]\w\[\e[0m\] \$ '
PS1='\[\e[1;34m\]╭─\[\e[1;32m\]●\[\e[0m\] \[\e[1;37m\]\w\[\e[0m\]\n\[\e[1;34m\]╰─\[\e[1;36m\]➜\[\e[0m\] '
PS1='\[\e[1;32m\]●\[\e[0m\] \[\e[1;36m\]➜\[\e[0m\] \[\e[1;37m\]\w\[\e[1;33m\]$(b=$(git_branch); [[ -n $b ]] && printf " (%s)" "$b")\[\e[0m\] \$ '
PS1='\[\e[1;34m\]╭─\[\e[1;32m\]●\[\e[0m\] \[\e[1;37m\]\w\[\e[1;33m\]$(__git_ps1 " (%s)")\[\e[0m\]\n\[\e[1;34m\]╰─\[\e[1;36m\]➜\[\e[0m\] '
PS1='\[\e[1;34m\]╭─\[\e[1;32m\]●\[\e[0m\] \[\e[1;36m\]\u@\h\[\e[0m\] \[\e[1;37m\]\w\[\e[1;33m\]$(__git_ps1 " (%s)")\[\e[0m\]\n\[\e[1;34m\]╰─\[\e[1;36m\]➜\[\e[0m\] '
PS1='\[\e[1;34m\]╭─\[\e[1;32m\]●\[\e[0m\] \
\[\e[1;33m\]\u\[\e[90m\]@\[\e[1;36m\]\h\[\e[0m\] \
\[\e[1;37m\]\w\[\e[1;35m\]$(__git_ps1 " (%s)")\[\e[0m\]\
\n\[\e[1;34m\]╰─\[\e[1;36m\]➜\[\e[0m\] '
#
git_branch() {
    __git_ps1 " (%s)"
}

set_ps1() {
    local status=$?
    local dot

    if (( status == 0 )); then
        dot='\[\e[1;32m\]●'   # Verde
    else
        dot='\[\e[1;31m\]●'   # Vermelha
    fi

    PS1="${dot}\[\e[0m\] \
\[\e[1;33m\]\u\[\e[90m\]@\[\e[1;36m\]\h\[\e[0m\] \
\[\e[1;37m\]\w\[\e[1;35m\]\$(git_branch)\[\e[0m\]\n\
\[\e[1;34m\]╰─\[\e[1;36m\]➜\[\e[0m\] "
}

PROMPT_COMMAND=set_ps1
